                <MenuItem x:Name="MenuItemFileSave" Header="{DynamicResource Str_0005}" Click="MenuItemFileSave_Click"/>
                <MenuItem x:Name="MenuItemFileSaveAs" Header="{DynamicResource Str_0006}" Click="MenuItemFileSaveAs_Click"/>
